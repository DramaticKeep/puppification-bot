{
  "name": "emotion-classifier",
  "version": "0.1.0",
  "description": "Classify the emotional tone of phrases and their sentences using GoEmotions (RoBERTa) via @huggingface/transformers.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "example": "node --import tsx examples/basic.ts",
    "test": "mocha",
    "test:integration": "mocha --config .mocharc.integration.json",
    "test:all": "npm test && npm run test:integration"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "nlp",
    "emotion",
    "tone",
    "classification",
    "goemotions",
    "transformers"
  ],
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
